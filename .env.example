# Add your n8n webhook URL and optional API key here.
# Example:
# NEXT_PUBLIC_N8N_WEBHOOK="https://your-n8n-url/webhook/abcd1234"
# NEXT_PUBLIC_N8N_API_KEY="your-api-key-if-you-use-it"

# Set your values below (do NOT commit secrets to public repos)
NEXT_PUBLIC_N8N_WEBHOOK=
NEXT_PUBLIC_N8N_API_KEY=

# Server-side webhook (kept secret) - used by `/api/quote`
# Example: N8N_WEBHOOK="https://your-n8n-url/webhook/abcd1234"
# For local development copy the public webhook (safe for local testing).
N8N_WEBHOOK=
# Optional server-side API key for n8n
N8N_API_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=
DATABASE_URL=